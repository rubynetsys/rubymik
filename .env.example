# RubyMIK configuration
# Every variable has a working default — you can run RubyMIK with no .env at all.
# Copy to .env and adjust only what you need.

# Port the web dashboard listens on (host side when using docker compose).
# Default: 8080
RUBYMIK_PORT=8080

# Directory where RubyMIK stores its SQLite database and generated secrets.
# In Docker this is /data (persisted via the compose volume) — leave it alone.
# For bare-metal runs it defaults to ./data next to the app.
# RUBYMIK_DATA_DIR=./data

# Log verbosity: debug | info | warn | error
# Default: info
RUBYMIK_LOG_LEVEL=info

# Seconds between background health poll cycles (5–3600).
# Polls are staggered and concurrency-capped — see "Polling at scale" in the README.
# Default: 30
RUBYMIK_POLL_INTERVAL=30

# Max devices polled in parallel within a cycle (1–16).
# Default: 4
RUBYMIK_POLL_CONCURRENCY=4

# Seconds between scheduled config-backup runs of all devices (60–2592000).
# Runs on its own low-frequency timer, independent of the metrics poller.
# Default: 86400 (daily)
RUBYMIK_BACKUP_INTERVAL=86400

# How many config backups to retain per device (1–500).
# Default: 10
RUBYMIK_BACKUP_KEEP=10

# OPTIONAL: 64-hex-char (32-byte) AES-256 key used to encrypt device
# credentials at rest. If unset, RubyMIK generates one on first run and
# stores it at <data dir>/secret.key with 0600 permissions.
# Generate your own with:  openssl rand -hex 32
# If you set this, keep it safe — losing it means re-entering device credentials.
# RUBYMIK_ENCRYPTION_KEY=

# P36 SELF-BACKUP KEY — a SEPARATE 64-hex-char (32-byte) key that encrypts
# RubyMIK's OWN database backups. This is NOT the field-encryption key above and
# MUST differ from it: the backup protects the whole DB file, including data that
# isn't field-encrypted. Until this is set, DB self-backups are DISABLED (the app
# warns loudly). Generate one from the Backup page (shown once) or:
#   openssl rand -hex 32
# CRITICAL: store this key somewhere OFF this machine. A backup is unreadable
# without it. Keep the key and the backups apart — together they are
# plaintext-equivalent. Never commit it.
# RUBYMIK_BACKUP_KEY=

# Optional self-backup tuning (defaults: every 6h, keep 28 = 7 days):
# RUBYMIK_SELFBACKUP_INTERVAL=21600
# RUBYMIK_SELFBACKUP_KEEP=28
